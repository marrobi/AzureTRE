{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://github.com/microsoft/AzureTRE/templates/workspace_services/fabric/template_schema.json",
  "type": "object",
  "title": "Microsoft Fabric",
  "description": "Microsoft Fabric workspace service with dedicated capacity, Lakehouse, and private connectivity.",
  "required": [],
  "properties": {
    "display_name": {
      "type": "string",
      "title": "Name for the workspace service",
      "description": "The name of the workspace service to be displayed to users",
      "default": "Microsoft Fabric",
      "updateable": true
    },
    "description": {
      "type": "string",
      "title": "Description of the workspace service",
      "description": "Description of the workspace service",
      "default": "Microsoft Fabric is a unified analytics platform that brings together data engineering, data science, real-time analytics, and business intelligence in a single SaaS experience.",
      "updateable": true
    },
    "overview": {
      "type": "string",
      "title": "Workspace Service Overview",
      "description": "Long form description of the workspace service, in markdown syntax",
      "default": "Microsoft Fabric provides a unified analytics platform built on a lakehouse architecture.\nThis workspace service provisions a dedicated Fabric capacity, workspace, and default Lakehouse with private connectivity to the TRE workspace.\n\n**Included resources:**\n- Fabric Capacity (configurable SKU)\n- Fabric Workspace with workspace-level private link\n- Default Lakehouse\n- Managed private endpoints for secure access to workspace storage\n\n[Microsoft Fabric documentation](https://learn.microsoft.com/en-us/fabric/)",
      "updateable": true
    },
    "fabric_capacity_sku": {
      "$id": "#/properties/fabric_capacity_sku",
      "type": "string",
      "title": "Fabric Capacity SKU",
      "description": "The SKU tier for the Fabric capacity. Larger SKUs provide more compute power but cost more.",
      "default": "F2",
      "enum": [
        "F2",
        "F4",
        "F8",
        "F16",
        "F32",
        "F64",
        "F128",
        "F256",
        "F512",
        "F1024",
        "F2048"
      ],
      "updateable": true
    },
    "is_exposed_externally": {
      "$id": "#/properties/is_exposed_externally",
      "type": "boolean",
      "title": "Expose externally",
      "description": "Is the Fabric workspace accessible from outside of the workspace network",
      "default": false
    },
    "workspace_owners_group_id": {
      "$id": "#/properties/workspace_owners_group_id",
      "type": "string",
      "title": "Workspace Owners Group ID",
      "description": "Object ID of the workspace owners AAD group",
      "updateable": true
    },
    "workspace_researchers_group_id": {
      "$id": "#/properties/workspace_researchers_group_id",
      "type": "string",
      "title": "Workspace Researchers Group ID",
      "description": "Object ID of the workspace researchers AAD group",
      "updateable": true
    }
  },
  "uiSchema": {
    "is_exposed_externally": {
      "classNames": "tre-hidden"
    },
    "workspace_owners_group_id": {
      "classNames": "tre-hidden"
    },
    "workspace_researchers_group_id": {
      "classNames": "tre-hidden"
    }
  },
  "pipeline": {
    "install": [
      {
        "stepId": "main",
        "properties": [
          {
            "name": "workspace_owners_group_id",
            "type": "string",
            "value": "{{ resource.parent.properties.workspace_owners_group_id }}"
          },
          {
            "name": "workspace_researchers_group_id",
            "type": "string",
            "value": "{{ resource.parent.properties.workspace_researchers_group_id }}"
          }
        ]
      },
      {
        "stepId": "f1a2b3c4-d5e6-7890-abcd-ef1234567890",
        "stepTitle": "Add firewall rules for Microsoft Fabric",
        "resourceTemplateName": "tre-shared-service-firewall",
        "resourceType": "shared-service",
        "resourceAction": "upgrade",
        "properties": [
          {
            "name": "network_rule_collections",
            "type": "array",
            "arraySubstitutionAction": "replace",
            "arrayMatchField": "name",
            "value": {
              "name": "nrc_svc_{{ resource.id }}_fabric",
              "action": "Allow",
              "rules": [
                {
                  "name": "Workspace_Authentication",
                  "description": "Workspace VM Authentication for Fabric",
                  "source_addresses": "{{ resource.properties.workspace_address_spaces }}",
                  "destination_addresses": [
                    "AzureActiveDirectory",
                    "AzureResourceManager"
                  ],
                  "destination_ports": [
                    "443"
                  ],
                  "protocols": [
                    "TCP"
                  ]
                }
              ]
            }
          },
          {
            "name": "rule_collections",
            "type": "array",
            "arraySubstitutionAction": "replace",
            "arrayMatchField": "name",
            "value": {
              "name": "arc_svc_{{ resource.id }}_fabric",
              "action": "Allow",
              "rules": [
                {
                  "name": "Fabric",
                  "description": "Microsoft Fabric portal and services. NOTE: FQDN list needs review for data exfiltration risk before merge - wildcards like *.powerbi.com, *.analysis.windows.net, *.notebooks.azure.net, and CDN domains (res.cdn.office.net, aznb-ame-prod.azureedge.net) should be assessed.",
                  "source_addresses": "{{ resource.properties.workspace_address_spaces }}",
                  "target_fqdns": [
                    "app.fabric.microsoft.com",
                    "api.fabric.microsoft.com",
                    "*.fabric.microsoft.com",
                    "*.powerbi.com",
                    "*.analysis.windows.net",
                    "*.pbidedicated.windows.net",
                    "*.frontend.clouddatahub.net",
                    "content.powerapps.com",
                    "login.microsoftonline.com",
                    "login.microsoft.com",
                    "aadcdn.msauth.net",
                    "*.msftauth.net",
                    "*.msauth.net",
                    "*.notebooks.azure.net",
                    "aznb-ame-prod.azureedge.net",
                    "dc.services.visualstudio.com",
                    "res.cdn.office.net",
                    "arc.msn.com"
                  ],
                  "protocols": [
                    {
                      "port": "443",
                      "type": "Https"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    ],
    "upgrade": [
      {
        "stepId": "main",
        "properties": [
          {
            "name": "workspace_owners_group_id",
            "type": "string",
            "value": "{{ resource.parent.properties.workspace_owners_group_id }}"
          },
          {
            "name": "workspace_researchers_group_id",
            "type": "string",
            "value": "{{ resource.parent.properties.workspace_researchers_group_id }}"
          }
        ]
      },
      {
        "stepId": "f1a2b3c4-d5e6-7890-abcd-ef1234567891",
        "stepTitle": "Update firewall rules for Microsoft Fabric",
        "resourceTemplateName": "tre-shared-service-firewall",
        "resourceType": "shared-service",
        "resourceAction": "upgrade",
        "properties": [
          {
            "name": "network_rule_collections",
            "type": "array",
            "arraySubstitutionAction": "replace",
            "arrayMatchField": "name",
            "value": {
              "name": "nrc_svc_{{ resource.id }}_fabric",
              "action": "Allow",
              "rules": [
                {
                  "name": "Workspace_Authentication",
                  "description": "Workspace VM Authentication for Fabric",
                  "source_addresses": "{{ resource.properties.workspace_address_spaces }}",
                  "destination_addresses": [
                    "AzureActiveDirectory",
                    "AzureResourceManager"
                  ],
                  "destination_ports": [
                    "443"
                  ],
                  "protocols": [
                    "TCP"
                  ]
                }
              ]
            }
          },
          {
            "name": "rule_collections",
            "type": "array",
            "arraySubstitutionAction": "replace",
            "arrayMatchField": "name",
            "value": {
              "name": "arc_svc_{{ resource.id }}_fabric",
              "action": "Allow",
              "rules": [
                {
                  "name": "Fabric",
                  "description": "Microsoft Fabric portal and services. NOTE: FQDN list needs review for data exfiltration risk before merge - wildcards like *.powerbi.com, *.analysis.windows.net, *.notebooks.azure.net, and CDN domains (res.cdn.office.net, aznb-ame-prod.azureedge.net) should be assessed.",
                  "source_addresses": "{{ resource.properties.workspace_address_spaces }}",
                  "target_fqdns": [
                    "app.fabric.microsoft.com",
                    "api.fabric.microsoft.com",
                    "*.fabric.microsoft.com",
                    "*.powerbi.com",
                    "*.analysis.windows.net",
                    "*.pbidedicated.windows.net",
                    "*.frontend.clouddatahub.net",
                    "content.powerapps.com",
                    "login.microsoftonline.com",
                    "login.microsoft.com",
                    "aadcdn.msauth.net",
                    "*.msftauth.net",
                    "*.msauth.net",
                    "*.notebooks.azure.net",
                    "aznb-ame-prod.azureedge.net",
                    "dc.services.visualstudio.com",
                    "res.cdn.office.net",
                    "arc.msn.com"
                  ],
                  "protocols": [
                    {
                      "port": "443",
                      "type": "Https"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    ],
    "uninstall": [
      {
        "stepId": "f1a2b3c4-d5e6-7890-abcd-ef1234567892",
        "stepTitle": "Remove firewall rules for Microsoft Fabric",
        "resourceTemplateName": "tre-shared-service-firewall",
        "resourceType": "shared-service",
        "resourceAction": "upgrade",
        "properties": [
          {
            "name": "network_rule_collections",
            "type": "array",
            "arraySubstitutionAction": "remove",
            "arrayMatchField": "name",
            "value": {
              "name": "nrc_svc_{{ resource.id }}_fabric"
            }
          },
          {
            "name": "rule_collections",
            "type": "array",
            "arraySubstitutionAction": "remove",
            "arrayMatchField": "name",
            "value": {
              "name": "arc_svc_{{ resource.id }}_fabric"
            }
          }
        ]
      },
      {
        "stepId": "main"
      }
    ]
  }
}